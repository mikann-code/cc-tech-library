#!/bin/sh
# cc-tech-library secret guard (pre-push)
# remote への最終防波堤。push 対象コミットのいずれかに秘匿語が含まれれば push を拒否する。
# （--no-verify や別ツールで作られたコミット、中間コミットに残った漏れも捕捉する）
# 秘匿語は pre-commit と同じ PATTERN を使う。

PATTERN='\bPANDA\b'
z40=0000000000000000000000000000000000000000

fail=0
while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue   # ブランチ削除は対象外
  if [ "$remote_sha" = "$z40" ]; then
    commits=$(git rev-list "$local_sha" --not --remotes)   # 新規ブランチ: 未push分すべて
  else
    commits=$(git rev-list "$remote_sha..$local_sha")
  fi
  for c in $commits; do
    hits=$(git grep -inE "$PATTERN" "$c" -- ':(exclude).githooks/*' 2>/dev/null)
    if [ -n "$hits" ]; then
      echo "🚫 push 対象コミット $(git rev-parse --short "$c") に秘匿語:"
      printf '%s\n' "$hits" | sed 's/^/    /'
      fail=1
    fi
  done
done

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "push を中止しました。該当コミットを履歴から除去/書き換えしてから再度 push してください。"
  exit 1
fi
exit 0
